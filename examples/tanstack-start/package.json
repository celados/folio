{
  "name": "@celados/folio-example-tanstack-start",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev --port 3000",
    "preview:e2e": "vp build && vp preview --host 127.0.0.1 --port 43173 --strictPort",
    "build": "vp build",
    "preview": "vp preview",
    "check": "vp check && bun run cf-typegen --check",
    "deploy": "vp build && wrangler deploy",
    "deploy:temporary": "vp build && wrangler deploy --temporary",
    "cf-typegen": "wrangler types src/worker-configuration.d.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@celados/folio": "workspace:*",
    "@celados/folio-example-world-development": "workspace:*",
    "@celados/folio-react": "workspace:*",
    "@fontsource-variable/inter": "^5.2.8",
    "@tailwindcss/vite": "^4",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "latest",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "lucide-react": "^1.24.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "ripple": "^0.3.108",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.46.0",
    "@duckdb/node-api": "^1.5.4-r.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/d3": "^7.4.3",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6",
    "jsdom": "^28",
    "typescript": "^6",
    "vite": "npm:@voidzero-dev/vite-plus-core",
    "vite-plus": "^0.2.5",
    "vitest": "4.1.10",
    "wrangler": "^4.110.0"
  },
  "overrides": {
    "vitest": "4.1.10"
  },
  "devEngines": {
    "packageManager": {
      "name": "bun",
      "version": "1.3.14",
      "onFail": "download"
    }
  }
}
